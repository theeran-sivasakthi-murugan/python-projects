def get_numbers():
    mass = float(input("Enter the mass in kilograms: "))
    acceleration = float(input("Enter the acceleration in m/s^2: "))
    return mass, acceleration

def calculate_force(mass, acceleration):
    force = mass * acceleration
    return force

def main():
    mass, acceleration = get_numbers()
    force = calculate_force(mass, acceleration)
    print(f"The force is: {force} Newtons")

if __name__ == "__main__":
    print("Welcome to the Force Calculator!")
    main()
